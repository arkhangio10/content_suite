# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxx
CLAUDE_MODEL_ORCHESTRATOR=claude-sonnet-4-6
CLAUDE_MODEL_WORKER=claude-haiku-4-5
CLAUDE_MODEL_SYNTHESIZER=claude-opus-4-7
CLAUDE_MODEL_EVALUATOR=claude-sonnet-4-6
CLAUDE_MODEL_VISION=claude-sonnet-4-6

# Groq (fallback)
GROQ_API_KEY=gsk_xxx
GROQ_MODEL=llama-3.3-70b-versatile

# Voyage AI (embeddings)
VOYAGE_API_KEY=pa-xxx
VOYAGE_MODEL=voyage-multilingual-2

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxx
SUPABASE_JWT_SECRET=xxx

# Database (direct connection for migrations)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxx.supabase.co:5432/postgres

# Langfuse
LANGFUSE_PUBLIC_KEY=pk-lf-xxx
LANGFUSE_SECRET_KEY=sk-lf-xxx
LANGFUSE_HOST=https://cloud.langfuse.com

# App config
APP_ENV=development
LOG_LEVEL=INFO
COST_CEILING_USD=2.00
MAX_REPAIR_ITERATIONS=2

# CORS (for frontend)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
