# Copy this file to .env.local and fill in your real values

# Supabase (browser-safe public keys)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxxx

# FastAPI backend (local dev)
VITE_API_BASE_URL=http://localhost:8000

# Langfuse public dashboard URL (for "open in Langfuse" links)
VITE_LANGFUSE_HOST=https://cloud.langfuse.com
